select job_title_short, salary_year_avg, 
CASE 
    WHEN job_location = 'Anywhere' THEN 'REMOTE'
    WHEN job_location = 'New York' THEN 'LOCAL'
    ELSE 'ONSITE'
END AS JOB_WORK_LOCATION
from job_postings_fact
WHERE salary_year_avg IS NOT NULL; 

select max(salary_year_avg) as maximun,
min(salary_year_avg) as minimum
from job_postings_fact;

--15000-70000 low 
