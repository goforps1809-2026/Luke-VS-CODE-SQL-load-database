--250000-960000 high
-- create a salary bucket?!
select job_title_short, job_location,salary_year_avg,
case 
    when salary_year_avg BETWEEN 15000 and 70000 then 'low'
    when salary_year_avg BETWEEN 70000 and 250000 then 'standard'
    else 'high'
end as salary_rating
from job_postings_fact
where job_title_short ='Data Analyst' and salary_year_avg IS NOT NULL;

select *
from (
    select *
    from job_postings_fact
    where extract(month from job_posted_date) = 12
) as december_jobs;

WITH may_jobs as 
    (SELECT * 
    FROM job_postings_fact
    where extract(month from job_posted_date)= 5)

select* 
from may_jobs
where job_title_short = 'Data Scientist';

--using subquery to get company name with no degree mention from dimension table 

select name as company_name
from company_dim
where company_id IN (
select company_id
from job_postings_fact
where job_no_degree_mention = TRUE) ; 

--using CTE & join, find out highest job postings per company

with company_count as 
    (select company_id, 
    count(*) as count
    from 
    job_postings_fact
    GROUP BY 
    company_id)

select company_dim.name, company_count.count
from company_dim
left join company_count on company_count.company_id = company_dim.company_id
order by company_count.count desc
limit 20;

select count(job_postings_fact.company_id) as count, name as company_name
from job_postings_fact
left join company_dim on company_dim.company_id = job_postings_fact.company_id
group by company_dim.name
order by job_postings_fact.count desc
limit 20;

