-- for JOINS ID SHOULD BE UNIQUE 

with CTE as (
    select 
        skill_id, 
        count(*) as count_skills
from 
    skills_job_dim as skills_on_job
inner join job_postings_fact as job_postings
on skills_on_job.job_id = job_postings.job_id
where 
    job_postings.job_work_from_home = TRUE
group by 
    skill_id) 

select 
    skills_d.skill_id, 
    skills as skill_name,
    count_skills
from CTE 
inner join skills_dim  as skills_d
on CTE.skill_id = skills_d.skill_id
order by 
    count_skills DESC;

